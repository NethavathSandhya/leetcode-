class Solution:
    def count(self, s: str) -> str :
        countOfchar = 1
        char = s[0]
        result = ""
        for i in range(1,len(s)) :
            if s[i] == char :
                countOfchar += 1
            else :
                result += str(countOfchar) + char
                char = s[i]
                countOfchar = 1
        result += str(countOfchar) + char
        return result
    def countAndSay(self, n: int) -> str:
        s = "1"
        for i in range(n - 1) :
            s = self.count(s)
        return s
        
